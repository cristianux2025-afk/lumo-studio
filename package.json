{
  "name": "lumo-studio",
  "version": "0.1.0",
  "description": "Estudio colaborativo de programación visual compatible con proyectos Scratch 3",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristianux2025-afk/lumo-studio.git"
  },
  "homepage": "https://lumo-studio-collab.onovatech1.chatgpt.site",
  "bugs": {
    "url": "https://github.com/cristianux2025-afk/lumo-studio/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run typecheck && npm run lint && npm run build && node tests/feature-contract.test.mjs && node tests/rendered-html.test.mjs",
    "test:browser": "node scripts/api-smoke.mjs && node scripts/cdp-smoke.mjs && node scripts/cdp-image-editor.mjs && node scripts/cdp-controls.mjs && node scripts/cdp-block-bridge.mjs && node scripts/cdp-collaboration.mjs",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app db scripts tests eslint.config.mjs vite.config.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@scratch/scratch-render": "14.1.0",
    "@scratch/scratch-svg-renderer": "14.1.0",
    "@scratch/scratch-vm": "14.1.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "scratch-audio": "2.0.268",
    "scratch-blocks": "2.1.19",
    "scratch-storage": "6.2.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@cloudflare/workers-types": "5.20260716.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.111.0"
  },
  "overrides": {
    "postcss": "8.5.19",
    "uuid": "11.1.1"
  },
  "type": "module"
}
